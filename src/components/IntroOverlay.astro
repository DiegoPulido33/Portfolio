<div id="intro-overlay" class="intro">
  <div class="intro__vignette"></div>

  <div class="intro__content">
    <div class="intro__title">Entrar a mi galaxia</div>
    <button id="intro-enter" class="intro__btn" type="button">
      Iniciar
    </button>
    <div class="intro__hint">Click para iniciar</div>
  </div>
</div>

<script>
  const overlay = document.getElementById("intro-overlay");
  const btn = document.getElementById("intro-enter");
  const saber = document.getElementById("lightsaber-cursor");

  function start() {
    if (!overlay) return;

    overlay.classList.add("intro--leaving");

    // opcional: activar sable justo al salir la intro
    if (saber) saber.style.display = "block";

    window.setTimeout(() => {
      overlay.remove();
    }, 900);
  }

  btn?.addEventListener("click", start);
  overlay?.addEventListener("click", (e) => {
    // evita doble click si pulsas el botón
    if ((e.target as HTMLElement).id !== "intro-enter") start();
  });
</script>

<style>
  .intro {
    position: fixed;
    inset: 0;
    z-index: 20000;
    background: radial-gradient(1200px 600px at 50% 55%, rgba(0, 255, 255, 0.10), rgba(0,0,0,0.92));
    display: grid;
    place-items: center;
  }

  .intro__vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 50%, rgba(0,0,0,0) 35%, rgba(0,0,0,0.85) 100%);
    pointer-events: none;
  }

  .intro__content {
    position: relative;
    text-align: center;
    padding: 28px 22px;
    border-radius: 18px;
    border: 1px solid rgba(0, 255, 255, 0.20);
    background: rgba(0, 20, 30, 0.22);
    box-shadow:
      0 0 24px rgba(0,255,255,0.16),
      inset 0 0 18px rgba(0,255,255,0.10);
    backdrop-filter: blur(10px);
  }

  .intro__title {
    color: #bff9ff;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 1px;
    text-shadow: 0 0 10px rgba(0,255,255,0.45);
    margin-bottom: 14px;
  }

  .intro__btn {
    appearance: none;
    border: 2px solid rgba(0, 255, 255, 0.35);
    background: rgba(0, 20, 30, 0.30);
    color: #bff9ff;
    padding: 12px 18px;
    border-radius: 14px;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: .5px;
    cursor: pointer;
    box-shadow: 0 0 16px rgba(0,255,255,0.18);
    transition: transform .15s ease, box-shadow .2s ease, border-color .2s ease;
  }

  .intro__btn:hover {
    transform: scale(1.03);
    border-color: rgba(0,255,255,0.7);
    box-shadow: 0 0 28px rgba(0,255,255,0.35);
  }

  .intro__hint {
    margin-top: 10px;
    color: rgba(191, 249, 255, 0.7);
    font-size: 12px;
    letter-spacing: 0.8px;
  }

  /* salida */
  .intro--leaving {
    animation: introFade 0.9s ease forwards;
  }

  @keyframes introFade {
    0% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(1.02); }
  }
</style>
