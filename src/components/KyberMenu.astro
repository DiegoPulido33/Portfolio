<div class="kyber-menu">
  <div class="menu-handle">
    <div class="arrow"></div>
  </div>

  <div class="kyber-panel metal-jedi">
    <img src="/crystals/kyber-blue.png" class="kyber-crystal" data-color="blue" />
    <img src="/crystals/kyber-green.png" class="kyber-crystal" data-color="green" />
    <img src="/crystals/kyber-red.png" class="kyber-crystal" data-color="red" />
    <img src="/crystals/kyber-purple.png" class="kyber-crystal" data-color="purple" />
    <img src="/crystals/kyber-yellow.png" class="kyber-crystal" data-color="yellow" />
  </div>
</div>

<script is:inline>
  const saber = document.getElementById("lightsaber-cursor");

  if (!saber) {
    console.error("[KyberMenu] No existe #lightsaber-cursor");
  }

  const saberPaths = {
    blue: "/sabers/saber-blue.png",
    green: "/sabers/saber-green.png",
    red: "/sabers/saber-red.png",
    purple: "/sabers/saber-purple.png",
    yellow: "/sabers/saber-yellow.png",
  };

  const kyberRgb = {
    blue: "103, 232, 249",
    green: "34, 197, 94",
    red: "239, 68, 68",
    purple: "168, 85, 247",
    yellow: "250, 204, 21",
  };

  const availableColors = Object.keys(saberPaths);

  function getRandomColor() {
    const randomIndex = Math.floor(Math.random() * availableColors.length);
    return availableColors[randomIndex];
  }

  function applyKyberColor(color) {
    if (!kyberRgb[color]) return;

    document.documentElement.style.setProperty("--kyber-rgb", kyberRgb[color]);
    document.documentElement.dataset.kyber = color;

    if (saber) {
      saber.src = saberPaths[color];
    }
  }

  function playIgnition() {
    const audio = new Audio("/audio/lightsaber/lightsaber-ignition.mp3");
    audio.volume = 1;
    audio.play().catch(() => {});
  }

  let currentColor = getRandomColor();

  applyKyberColor(currentColor);

  document.querySelectorAll(".kyber-crystal").forEach((el) => {
    el.addEventListener("click", () => {
      const color = el.dataset.color;
      if (!color || color === currentColor) return;

      currentColor = color;
      applyKyberColor(color);
      playIgnition();
    });
  });
</script>

<style>
  @import "../styles/KyberMenu.css";
</style>