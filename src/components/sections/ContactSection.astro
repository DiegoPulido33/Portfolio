---
import { contactContent } from "../../data/contactContent";
import SectionNavigator from "../sectionNavigator.astro";

const {
  eyebrow,
  title,
  intro,
  availability,
  statement,
  channels,
  closingNote,
} = contactContent;
---

<section id="contact" class="section-contact" data-zone="contact-channel">
  <div class="contact-bg-grid"></div>

  <div class="contact-shell">
    <header class="contact-header">
      <p class="contact-header__eyebrow">{eyebrow}</p>
      <h1 class="contact-header__title">{title}</h1>
      <p class="contact-header__intro">{intro}</p>
    </header>

    <div class="contact-form-shell">
      <div class="contact-form-copy">
        <span>Contacto directo</span>
        <h2>Envíame una consulta</h2>
        <p>
          Si tienes una oportunidad, proyecto o conversación profesional
          interesante, puedes escribirme desde este formulario.
        </p>
      </div>

      <form class="contact-form" id="contact-form">
        <div class="contact-form__row">
          <label>
            Nombre
            <input name="name" type="text" required autocomplete="name" />
          </label>

          <label>
            Email
            <input name="email" type="email" required autocomplete="email" />
          </label>
        </div>

        <label>
          Empresa / contexto
          <input name="company" type="text" autocomplete="organization" />
        </label>

        <label>
          Mensaje
          <textarea name="message" rows="5" required></textarea>
        </label>

        <button type="submit">Enviar mensaje</button>

        <p class="contact-form__status" id="contact-form-status"></p>
      </form>
    </div>

    <div class="contact-layout contact-layout--with-form">
      <aside class="contact-panel">
        <span class="contact-panel__label">{availability.label}</span>
        <strong class="contact-panel__status">{availability.value}</strong>
        <p>{statement}</p>
      </aside>

      <div class="contact-cards">
        {
          channels.map((channel) => (
            <article class="contact-card">
              <div>
                <span class="contact-card__label">{channel.label}</span>
                <p class="contact-card__value">{channel.value}</p>
              </div>

              {channel.href ? (
                <a
                  class="contact-card__action"
                  href={channel.href}
                  target={
                    channel.href.startsWith("http") ? "_blank" : undefined
                  }
                  rel={
                    channel.href.startsWith("http")
                      ? "noopener noreferrer"
                      : undefined
                  }
                >
                  {channel.action}
                </a>
              ) : (
                <span class="contact-card__action contact-card__action--static">
                  {channel.action}
                </span>
              )}
            </article>
          ))
        }
      </div>
    </div>

    <footer class="contact-footer">
      <p>{closingNote}</p>
    </footer>
  </div>

  <SectionNavigator current="contact" />
</section>

<script is:inline>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("contact-form-status");

  if (form && status) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      status.textContent = "Enviando mensaje...";

      const submitButton = form.querySelector("button");
      if (submitButton) submitButton.disabled = true;

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          throw new Error("No se pudo enviar el mensaje.");
        }

        form.reset();
        status.textContent = "Mensaje enviado correctamente.";
      } catch {
        status.textContent =
          "No se pudo enviar el mensaje. Puedes contactarme directamente por email.";
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });
  }
</script>
