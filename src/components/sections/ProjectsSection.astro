---
import { projectsContent } from "../../data/projectsContent";
import SectionNavigator from "../sectionNavigator.astro";
import ProjectDeck from "./projectDeck";

const { eyebrow, title, intro, featuredProjects, sectionNote } =
  projectsContent;
---

<section
  class="section-zone section-zone--projects"
  id="projects"
  data-zone="orbital-hangar"
>
  <div class="section-zone__shell">
    <header class="section-zone__header projects-header">
      <p class="section-zone__eyebrow">{eyebrow}</p>
      <h1 class="section-zone__title">{title}</h1>
      <p class="section-zone__intro">{intro}</p>
    </header>

    <div class="section-zone__content projects-zone__content">
      <ProjectDeck client:load projects={featuredProjects} />
    </div>

    <footer class="section-zone__footer projects-footer">
      <p>{sectionNote}</p>
    </footer>
  </div>
  <SectionNavigator current="projects" />
</section>
