---
import "../styles/global.css";
import "../styles/sections/experience.css";

import GalaxyCanvas from "../components/GalaxyCanvas.astro";
import KyberMenu from "../components/KyberMenu.astro";
import CockpitIntro from "../components/CockpitIntro.astro";
import SystemControls from "../components/SystemControls.astro";
import ExperienceSection from "../components/sections/ExperienceSection.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Portfolio Galaxy</title>
  </head>

  <body>
    <GalaxyCanvas />

    <!-- SABLE -->
    <img
      id="lightsaber-cursor"
      src="/sabers/saber-blue.png"
      alt="Lightsaber cursor"
    />

    <!-- INTRO -->
    <CockpitIntro />

    <!-- UI / HUB -->
    <div id="main-ui">
      <KyberMenu />
      <SystemControls />

      <div id="portal-container" class="bridge-hub">
        <div class="command-deck">
          <div class="command-deck__platform"></div>

          <div class="command-nav">
            <button
              class="command-node command-node--projects"
              data-target="projects"
            >
              <span class="command-node__panel">
                <span class="command-node__title">Proyectos</span>
              </span>
            </button>

            <button
              class="command-node command-node--experience"
              data-target="experience"
            >
              <span class="command-node__panel">
                <span class="command-node__title">Experiencia</span>
              </span>
            </button>

            <button
              class="command-node command-node--tech"
              data-target="technologies"
            >
              <span class="command-node__panel">
                <span class="command-node__title">Tecnologías</span>
              </span>
            </button>

            <button
              class="command-node command-node--contact"
              data-target="contact"
            >
              <span class="command-node__panel">
                <span class="command-node__title">Contacto</span>
              </span>
            </button>
          </div>
        </div>
      </div>

      <script>
        import "../scenes/MainLightsaberCursor.ts";

        const mainUi = document.getElementById("main-ui");

        window.addEventListener("cockpit:intro-finished", () => {
          if (!mainUi) return;
          mainUi.classList.add("main-ui-visible");
        });

        const commandNodes = document.querySelectorAll(
          ".command-node[data-target]",
        );

        commandNodes.forEach((node) => {
          node.addEventListener("click", () => {
            const targetId = node.getAttribute("data-target");
            if (!targetId) return;

            const target = document.getElementById(targetId);
            if (!target) return;

            target.scrollIntoView({
              behavior: "smooth",
              block: "start",
            });
          });
        });
      </script>
    </div>

    <!-- UNIVERSO DE SECCIONES -->
    <main id="portfolio-universe">
      <ExperienceSection />
    </main>
  </body>
</html>
