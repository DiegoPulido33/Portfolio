---
import "../styles/global.css";
import GalaxyCanvas from "../components/GalaxyCanvas.astro";
import KyberMenu from "../components/KyberMenu.astro";
import CockpitIntro from "../components/CockpitIntro.astro";
import HoloPlanetCanvas from "../components/HoloPlanetCanvas.astro";
import SystemControls from "../components/SystemControls.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Portfolio Galaxy</title>
  </head>

  <body>
    <GalaxyCanvas />

    <!-- SABLE -->
    <img
      id="lightsaber-cursor"
      src="/sabers/saber-blue.png"
      alt="Lightsaber cursor"
    />

    <!-- INTRO -->
    <CockpitIntro />

    <!-- UI OCULTA AL INICIO -->
    <div id="main-ui">
      <KyberMenu />
      <SystemControls />

      <div id="portal-container" class="bridge-hub">
        <div class="bridge-window"></div>

        <div class="bridge-table">
          <div class="bridge-table__surface"></div>

          <div class="holo-core">
            <HoloPlanetCanvas />

            <button class="orbit-node orbit-node--about">
              <span class="orbit-node__pulse"></span>
              <span class="orbit-node__label">Sobre mí</span>
            </button>

            <button class="orbit-node orbit-node--projects">
              <span class="orbit-node__pulse"></span>
              <span class="orbit-node__label">Proyectos</span>
            </button>

            <button class="orbit-node orbit-node--future">
              <span class="orbit-node__pulse"></span>
              <span class="orbit-node__label">Ideas Futuras</span>
            </button>

            <button class="orbit-node orbit-node--contact">
              <span class="orbit-node__pulse"></span>
              <span class="orbit-node__label">Contacto</span>
            </button>
          </div>
        </div>
      </div>

      <script>
        import "../scenes/MainLightsaberCursor.ts";

        const mainUi = document.getElementById("main-ui");

        window.addEventListener("cockpit:intro-finished", () => {
          if (!mainUi) return;
          mainUi.classList.add("main-ui-visible");
        });
      </script>
    </div>
  </body>
</html>
